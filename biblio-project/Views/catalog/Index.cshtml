@model biblio_project.Models.CatalogViewModel

@{
    ViewData["Title"] = "Catalogue";
}

<!-- En-tête -->
<div class="d-flex align-items-start justify-content-between mb-4 flex-wrap gap-3">
    <div>
        <h1 class="section-title" style="font-size:1.8rem">Catalogue des livres</h1>
        <p class="text-ink-muted mb-0">
            @Model.TotalBooks livre(s) référencé(s)
            @if (!string.IsNullOrWhiteSpace(Model.SearchQuery) || Model.CategoryId.HasValue)
            {
                @: — résultats filtrés
            }
        </p>
    </div>
    <!-- Export PDF -->
    <a asp-action="ExportPdf"
       asp-route-search="@Model.SearchQuery"
       asp-route-categoryId="@Model.CategoryId"
       asp-route-availableOnly="@Model.AvailableOnly"
       class="btn btn-outline-secondary btn-sm" target="_blank">
        <i class="fas fa-file-pdf me-2" style="color:#DC2626"></i>Exporter en PDF
    </a>
</div>

<!-- Filtres -->
<div class="search-card mb-4">
    <form asp-action="Index" method="get">
        <div class="row g-3">
            <div class="col-md-4">
                <label for="search" class="form-label">
                    <i class="fas fa-search me-1"></i>Recherche
                </label>
                <input type="text" class="form-control" id="search" name="search"
                       value="@Model.SearchQuery" placeholder="Titre, auteur, résumé…">
            </div>

            <div class="col-md-3">
                <label for="categoryId" class="form-label">
                    <i class="fas fa-tag me-1"></i>Catégorie
                </label>
                <select class="form-select" id="categoryId" name="categoryId">
                    <option value="">Toutes les catégories</option>
                    @foreach (var category in Model.Categories)
                    {
                        if (Model.CategoryId == category.Id)
                        {
                            <option value="@category.Id" selected>@category.Name</option>
                        }
                        else
                        {
                            <option value="@category.Id">@category.Name</option>
                        }
                    }
                </select>
            </div>

            <div class="col-md-2">
                <label for="year" class="form-label">
                    <i class="fas fa-calendar me-1"></i>Année
                </label>
                <input type="number" class="form-control" id="year" name="year"
                       value="@Model.PublicationYear" placeholder="Ex : 2020"
                       min="1800" max="@DateTime.Now.Year">
            </div>

            <div class="col-md-3 d-flex align-items-end gap-3 flex-wrap">
                <div class="form-check mt-1">
                    <input class="form-check-input" type="checkbox" id="availableOnly"
                           name="availableOnly" value="true"
                           @(Model.AvailableOnly == true ? "checked" : "")>
                    <label class="form-check-label" for="availableOnly">
                        Disponibles seulement
                    </label>
                </div>
            </div>
        </div>

        <div class="d-flex gap-2 mt-3">
            <button type="submit" class="btn btn-primary btn-sm">
                <i class="fas fa-search me-1"></i>Rechercher
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
                <i class="fas fa-redo me-1"></i>Réinitialiser
            </a>
        </div>
    </form>
</div>

<!-- Grille de livres -->
@if (Model.Books.Any())
{
    <div class="row g-4">
        @foreach (var book in Model.Books)
        {
            <div class="col-sm-6 col-md-4 col-lg-3 fade-in-up">
                <div class="card h-100 book-card">
                    @if (!string.IsNullOrEmpty(book.CoverImageUrl))
                    {
                        <img src="@book.CoverImageUrl" class="card-img-top" alt="@book.Title"
                             style="height:260px;object-fit:cover">
                    }
                    else
                    {
                        <div class="no-cover" style="height:260px">
                            <i class="fas fa-book"></i>
                        </div>
                    }

                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title" style="font-size:1rem;line-height:1.3;margin-bottom:.4rem">
                            @book.Title
                        </h5>

                        @if (!string.IsNullOrEmpty(book.AuthorNamesText))
                        {
                            <p class="text-ink-muted mb-1" style="font-size:.82rem">
                                <i class="fas fa-user me-1"></i>@book.AuthorNamesText
                            </p>
                        }

                        @if (book.PublicationYear.HasValue)
                        {
                            <p class="text-ink-muted mb-1" style="font-size:.82rem">
                                <i class="fas fa-calendar me-1"></i>@book.PublicationYear
                            </p>
                        }

                        @if (!string.IsNullOrEmpty(book.MainCategoryName))
                        {
                            <p class="mb-2">
                                <span class="badge bg-primary" style="font-size:.72rem">@book.MainCategoryName</span>
                            </p>
                        }

                        <div class="mt-auto pt-2" style="border-top:1px solid var(--ivory-dark)">
                            @if (book.AvailableCopiesCount > 0)
                            {
                                <div class="avail-badge available d-inline-flex mb-2">
                                    <i class="fas fa-check-circle"></i>
                                    @book.AvailableCopiesCount dispo.
                                </div>
                            }
                            else
                            {
                                <div class="avail-badge unavailable d-inline-flex mb-2">
                                    <i class="fas fa-times-circle"></i>
                                    Indisponible
                                </div>
                            }
                            <br>
                            <a asp-action="Details" asp-route-id="@book.Id"
                               class="btn btn-primary btn-sm w-100">
                                <i class="fas fa-info-circle me-1"></i>Voir le détail
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Pagination -->
    @if (Model.TotalPages > 1)
    {
        <nav class="mt-5" aria-label="Navigation des pages">
            <div class="text-center text-ink-muted mb-3" style="font-size:.85rem">
                Page @Model.CurrentPage sur @Model.TotalPages —
                @Model.TotalBooks résultat(s)
            </div>
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-search="@Model.SearchQuery"
                       asp-route-categoryId="@Model.CategoryId"
                       asp-route-authorId="@Model.AuthorId"
                       asp-route-availableOnly="@Model.AvailableOnly"
                       asp-route-year="@Model.PublicationYear"
                       asp-route-page="@(Model.CurrentPage - 1)">
                        <i class="fas fa-chevron-left"></i>
                    </a>
                </li>

                @{
                    int startPage = Math.Max(1, Model.CurrentPage - 2);
                    int endPage = Math.Min(Model.TotalPages, Model.CurrentPage + 2);
                }

                @if (startPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="Index" asp-route-page="1"
                           asp-route-search="@Model.SearchQuery" asp-route-categoryId="@Model.CategoryId"
                           asp-route-availableOnly="@Model.AvailableOnly" asp-route-year="@Model.PublicationYear">1</a>
                    </li>
                    @if (startPage > 2)
                    {
                        <li class="page-item disabled"><span class="page-link">…</span></li>
                    }
                }

                @for (int i = startPage; i <= endPage; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" asp-action="Index"
                           asp-route-search="@Model.SearchQuery"
                           asp-route-categoryId="@Model.CategoryId"
                           asp-route-authorId="@Model.AuthorId"
                           asp-route-availableOnly="@Model.AvailableOnly"
                           asp-route-year="@Model.PublicationYear"
                           asp-route-page="@i">@i</a>
                    </li>
                }

                @if (endPage < Model.TotalPages)
                {
                    @if (endPage < Model.TotalPages - 1)
                    {
                        <li class="page-item disabled"><span class="page-link">…</span></li>
                    }
                    <li class="page-item">
                        <a class="page-link" asp-action="Index" asp-route-page="@Model.TotalPages"
                           asp-route-search="@Model.SearchQuery" asp-route-categoryId="@Model.CategoryId"
                           asp-route-availableOnly="@Model.AvailableOnly" asp-route-year="@Model.PublicationYear">
                            @Model.TotalPages
                        </a>
                    </li>
                }

                <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-search="@Model.SearchQuery"
                       asp-route-categoryId="@Model.CategoryId"
                       asp-route-authorId="@Model.AuthorId"
                       asp-route-availableOnly="@Model.AvailableOnly"
                       asp-route-year="@Model.PublicationYear"
                       asp-route-page="@(Model.CurrentPage + 1)">
                        <i class="fas fa-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    }
}
else
{
    <div class="text-center py-5">
        <i class="fas fa-search fa-3x text-ink-muted mb-3"></i>
        <h4 style="font-family:'Playfair Display',serif">Aucun livre trouvé</h4>
        <p class="text-ink-muted">Essayez de modifier vos critères de recherche.</p>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="fas fa-redo me-1"></i>Réinitialiser les filtres
        </a>
    </div>
}
