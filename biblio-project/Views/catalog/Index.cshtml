@model biblio_project.Models.CatalogViewModel

@{
    ViewData["Title"] = "Catalogue";
}

<div class="row mb-4">
    <div class="col-12">
        <h1 class="display-4">
            <i class="fas fa-book"></i> Catalogue des livres
        </h1>
        <p class="text-muted">@Model.TotalBooks livre(s) disponible(s)</p>
    </div>
</div>

<!-- Formulaire de recherche et filtres -->
<div class="row mb-4">
    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-body">
                <form asp-action="Index" method="get">
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label for="search" class="form-label">
                                <i class="fas fa-search"></i> Recherche
                            </label>
                            <input type="text" class="form-control" id="search" name="search" 
                                   value="@Model.SearchQuery" placeholder="Titre, auteur, résumé...">
                        </div>
                        
                        <div class="col-md-3 mb-3">
                            <label for="categoryId" class="form-label">
                                <i class="fas fa-tag"></i> Catégorie
                            </label>
                            <select class="form-select" id="categoryId" name="categoryId">
                                <option value="">Toutes les catégories</option>
                                @foreach (var category in Model.Categories)
                                {
                                    <option value="@category.Id" selected="@(Model.CategoryId == category.Id)">
                                        @category.Name
                                    </option>
                                }
                            </select>
                        </div>
                        
                        <div class="col-md-2 mb-3">
                            <label for="year" class="form-label">
                                <i class="fas fa-calendar"></i> Année
                            </label>
                            <input type="number" class="form-control" id="year" name="year" 
                                   value="@Model.PublicationYear" placeholder="Ex: 2024">
                        </div>
                        
                        <div class="col-md-3 mb-3">
                            <label class="form-label d-block">&nbsp;</label>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="availableOnly" 
                                       name="availableOnly" value="true" checked="@(Model.AvailableOnly == true)">
                                <label class="form-check-label" for="availableOnly">
                                    Disponibles uniquement
                                </label>
                            </div>
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-12">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-search"></i> Rechercher
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="fas fa-redo"></i> Réinitialiser
                            </a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Liste des livres -->
<div class="row">
    @if (Model.Books.Any())
    {
        @foreach (var book in Model.Books)
        {
            <div class="col-md-4 col-lg-3 mb-4">
                <div class="card h-100 shadow-sm book-card">
                    @if (!string.IsNullOrEmpty(book.CoverImageUrl))
                    {
                        <img src="@book.CoverImageUrl" class="card-img-top" alt="@book.Title" 
                             style="height: 300px; object-fit: cover;">
                    }
                    else
                    {
                        <div class="card-img-top bg-secondary d-flex align-items-center justify-content-center" 
                             style="height: 300px;">
                            <i class="fas fa-book fa-5x text-white"></i>
                        </div>
                    }
                    
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@book.Title</h5>
                        
                        @if (!string.IsNullOrEmpty(book.AuthorNamesText))
                        {
                            <p class="card-text text-muted small mb-2">
                                <i class="fas fa-user"></i> @book.AuthorNamesText
                            </p>
                        }
                        
                        @if (book.PublicationYear.HasValue)
                        {
                            <p class="card-text text-muted small mb-2">
                                <i class="fas fa-calendar"></i> @book.PublicationYear
                            </p>
                        }
                        
                        @if (!string.IsNullOrEmpty(book.MainCategoryName))
                        {
                            <p class="card-text mb-2">
                                <span class="badge bg-primary">@book.MainCategoryName</span>
                            </p>
                        }
                        
                        <div class="mt-auto">
                            @if (book.AvailableCopiesCount > 0)
                            {
                                <p class="text-success mb-2">
                                    <i class="fas fa-check-circle"></i> 
                                    @book.AvailableCopiesCount exemplaire(s) disponible(s)
                                </p>
                            }
                            else
                            {
                                <p class="text-danger mb-2">
                                    <i class="fas fa-times-circle"></i> Indisponible
                                </p>
                            }
                            
                            <a asp-action="Details" asp-route-id="@book.Id" class="btn btn-primary btn-sm w-100">
                                <i class="fas fa-info-circle"></i> Détails
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12">
            <div class="alert alert-info text-center">
                <i class="fas fa-info-circle fa-3x mb-3"></i>
                <h4>Aucun livre trouvé</h4>
                <p>Essayez de modifier vos critères de recherche</p>
            </div>
        </div>
    }
</div>

<!-- Pagination -->
@if (Model.TotalPages > 1)
{
    <nav aria-label="Navigation des pages">
        <ul class="pagination justify-content-center">
            <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index" 
                   asp-route-search="@Model.SearchQuery"
                   asp-route-categoryId="@Model.CategoryId"
                   asp-route-authorId="@Model.AuthorId"
                   asp-route-availableOnly="@Model.AvailableOnly"
                   asp-route-year="@Model.PublicationYear"
                   asp-route-page="@(Model.CurrentPage - 1)">
                    Précédent
                </a>
            </li>
            
            @for (int i = Math.Max(1, Model.CurrentPage - 2); i <= Math.Min(Model.TotalPages, Model.CurrentPage + 2); i++)
            {
                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-search="@Model.SearchQuery"
                       asp-route-categoryId="@Model.CategoryId"
                       asp-route-authorId="@Model.AuthorId"
                       asp-route-availableOnly="@Model.AvailableOnly"
                       asp-route-year="@Model.PublicationYear"
                       asp-route-page="@i">
                        @i
                    </a>
                </li>
            }
            
            <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Index"
                   asp-route-search="@Model.SearchQuery"
                   asp-route-categoryId="@Model.CategoryId"
                   asp-route-authorId="@Model.AuthorId"
                   asp-route-availableOnly="@Model.AvailableOnly"
                   asp-route-year="@Model.PublicationYear"
                   asp-route-page="@(Model.CurrentPage + 1)">
                    Suivant
                </a>
            </li>
        </ul>
    </nav>
}

<style>
    .book-card {
        transition: transform 0.2s;
    }
    
    .book-card:hover {
        transform: translateY(-5px);
    }
</style>