@model biblio_project.Models.BookDetail

@{
ViewData["Title"] = Model.Title;
// Fix critique : lire l'userId depuis le claim (passé par le controller)
var authenticatedUserId = ViewData["AuthenticatedUserId"]?.ToString() ?? string.Empty;
var isAuthenticated = !string.IsNullOrEmpty(authenticatedUserId);
}

<div class="mb-4">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="fas fa-arrow-left me-1"></i> Retour au catalogue
    </a>
</div>

<div class="row g-4">
    <!-- Colonne gauche : couverture + actions -->
    <div class="col-md-4 col-lg-3">
        <div style="position:sticky;top:1.5rem">
            @if (!string.IsNullOrEmpty(Model.CoverImageUrl))
            {
            <img src="@Model.CoverImageUrl" class="img-fluid rounded shadow mb-3"
                 alt="@Model.Title" style="width:100%;object-fit:cover;border:1px solid var(--ivory-dark)">
            }
            else
            {
            <div class="book-card no-cover rounded shadow mb-3" style="height:360px">
                <i class="fas fa-book"></i>
            </div>
            }

            <!-- Disponibilité -->
            <div class="card mb-3">
                <div class="card-body p-3 text-center">
                    @if (Model.IsAvailable)
                    {
                    <div class="avail-badge available d-inline-flex mb-3">
                        <i class="fas fa-check-circle"></i>
                        <strong>@Model.AvailableCopiesCount</strong>&nbsp;exemplaire(s) disponible(s)
                    </div>

                    @if (isAuthenticated)
                    {
                    <button type="button" class="btn btn-primary w-100 mb-2"
                            onclick="borrowBook(@Model.Id)">
                        <i class="fas fa-book-reader me-2"></i>Emprunter
                    </button>
                    }
                    else
                    {
                    <a asp-controller="Account" asp-action="Login"
                       asp-route-returnUrl="@Context.Request.Path"
                       class="btn btn-primary w-100 mb-2">
                        <i class="fas fa-sign-in-alt me-2"></i>Connectez-vous pour emprunter
                    </a>
                    }
                    }
                    else
                    {
                    <div class="avail-badge unavailable d-inline-flex mb-3">
                        <i class="fas fa-times-circle"></i>
                        Aucun exemplaire disponible
                    </div>

                    @if (isAuthenticated)
                    {
                    <button type="button" class="btn btn-warning w-100 mb-2" style="color:white"
                            onclick="reserveBook(@Model.Id)">
                        <i class="fas fa-bookmark me-2"></i>Réserver
                    </button>
                    }
                    else
                    {
                    <a asp-controller="Account" asp-action="Login"
                       asp-route-returnUrl="@Context.Request.Path"
                       class="btn btn-warning w-100 mb-2" style="color:white">
                        <i class="fas fa-sign-in-alt me-2"></i>Connectez-vous pour réserver
                    </a>
                    }
                    }

                    <p class="text-ink-muted mb-0" style="font-size:.8rem">
                        @Model.TotalCopiesCount exemplaire(s) au total
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- Colonne droite : détails -->
    <div class="col-md-8 col-lg-9">
        <h1 style="font-family:'Playfair Display',serif;font-weight:700;font-size:clamp(1.6rem,3vw,2.4rem);line-height:1.2;margin-bottom:.5rem">
            @Model.Title
        </h1>

        @if (!string.IsNullOrEmpty(Model.Subtitle))
        {
        <p class="lead text-ink-muted mb-3" style="font-style:italic">@Model.Subtitle</p>
        }

        <hr style="border-color:var(--ivory-dark);margin:1.25rem 0">

        <!-- Métadonnées -->
        <div class="row g-2 mb-4">
            @if (Model.Authors.Any())
            {
            <div class="col-sm-6">
                <div style="font-size:.8rem;text-transform:uppercase;letter-spacing:.06em;color:var(--ink-muted);font-weight:600;margin-bottom:.2rem">
                    <i class="fas fa-user me-1"></i>Auteur(s)
                </div>
                <div style="font-weight:600">@string.Join(", ", Model.Authors.Select(a => a.FullName))</div>
            </div>
            }

            @if (Model.PublicationYear.HasValue)
            {
            <div class="col-sm-3">
                <div style="font-size:.8rem;text-transform:uppercase;letter-spacing:.06em;color:var(--ink-muted);font-weight:600;margin-bottom:.2rem">
                    <i class="fas fa-calendar me-1"></i>Année
                </div>
                <div style="font-weight:600">@Model.PublicationYear</div>
            </div>
            }

            @if (!string.IsNullOrEmpty(Model.PublisherName))
            {
            <div class="col-sm-3">
                <div style="font-size:.8rem;text-transform:uppercase;letter-spacing:.06em;color:var(--ink-muted);font-weight:600;margin-bottom:.2rem">
                    <i class="fas fa-building me-1"></i>Éditeur
                </div>
                <div style="font-weight:600">@Model.PublisherName</div>
            </div>
            }

            @if (Model.Categories.Any())
            {
            <div class="col-12">
                <div style="font-size:.8rem;text-transform:uppercase;letter-spacing:.06em;color:var(--ink-muted);font-weight:600;margin-bottom:.4rem">
                    <i class="fas fa-tags me-1"></i>Catégories
                </div>
                @foreach (var category in Model.Categories)
                {
                <span class="badge bg-primary me-1">@category.Name</span>
                }
            </div>
            }
        </div>


        <!-- Statistiques d'emprunt -->
        <div class="card mb-4">
            <div class="card-body">
                <h5 class="card-title" style="font-size:1rem;text-transform:uppercase;letter-spacing:.04em;color:var(--ink-muted);margin-bottom:.75rem">
                    <i class="fas fa-chart-bar me-2"></i>Statistiques d'emprunt
                </h5>
                <div class="row g-3 text-center">
                    <div class="col-6">
                        <div style="font-size:2rem;font-weight:700;font-family:'Playfair Display',serif">
                            @Model.TotalLoansCount
                        </div>
                        <div style="font-size:.82rem;color:var(--ink-muted)">emprunt(s) au total</div>
                    </div>
                    <div class="col-6">
                        <div style="font-size:2rem;font-weight:700;font-family:'Playfair Display',serif">
                            @Model.CurrentActiveLoansCount
                        </div>
                        <div style="font-size:.82rem;color:var(--ink-muted)">emprunt(s) en cours</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Biographies auteurs -->
        @if (Model.Authors.Any(a => !string.IsNullOrEmpty(a.Bio)))
        {
        <div class="card mb-4">
            <div class="card-body">
                <h5 class="card-title" style="font-size:1rem;text-transform:uppercase;letter-spacing:.04em;color:var(--ink-muted);margin-bottom:.75rem">
                    <i class="fas fa-info-circle me-2"></i>À propos de l'auteur
                </h5>
                @foreach (var author in Model.Authors.Where(a => !string.IsNullOrEmpty(a.Bio)))
                {
                <div class="mb-3">
                    <h6 style="font-family:'Playfair Display',serif;font-size:1rem;margin-bottom:.25rem">
                        @author.FullName
                    </h6>
                    @if (author.BirthYear.HasValue)
                    {
                    <p class="text-ink-muted mb-1" style="font-size:.82rem">
                        Né en @author.BirthYear
                        @if (author.DeathYear.HasValue)
                        {
                        @: — Décédé en @author.DeathYear
                        }
                    </p>
                    }
                    <p class="mb-0" style="font-size:.95rem;line-height:1.7">@author.Bio</p>
                </div>
                }
            </div>
        </div>
        }
    </div>
</div>

<!-- Modal message -->
<div class="modal fade" id="messageModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="messageModalTitle"></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="messageModalBody"></div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Fermer</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // userId lu depuis le claim authentifié — plus jamais Guid.NewGuid()
    const userId = '@authenticatedUserId';
    const isAuthenticated = @(isAuthenticated ? "true" : "false");

    function borrowBook(bookId) {
        if (!isAuthenticated) { window.location.href = '/Account/Login'; return; }
        if (!confirm('Voulez-vous emprunter ce livre ?')) return;

        fetch('/api/loans/borrow', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ bookId, userId })
        })
            .then(r => r.json())
            .then(data => {
                showMessage(data.success ? 'Succès' : 'Erreur', data.message, data.success ? 'success' : 'danger');
                if (data.success) setTimeout(() => location.reload(), 1800);
            })
            .catch(() => showMessage('Erreur', "Une erreur est survenue lors de l'emprunt", 'danger'));
    }

    function reserveBook(bookId) {
        if (!isAuthenticated) { window.location.href = '/Account/Login'; return; }
        if (!confirm('Voulez-vous réserver ce livre ?')) return;

        fetch('/api/reservations/reserve', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ bookId, userId })
        })
            .then(r => r.json())
            .then(data => {
                showMessage(data.success ? 'Succès' : 'Erreur', data.message, data.success ? 'success' : 'danger');
                if (data.success) setTimeout(() => location.reload(), 1800);
            })
            .catch(() => showMessage('Erreur', "Une erreur est survenue lors de la réservation", 'danger'));
    }

    function showMessage(title, message, type) {
        document.getElementById('messageModalTitle').textContent = title;
        document.getElementById('messageModalBody').innerHTML =
            `<div class="alert alert-${type} mb-0">${message}</div>`;
        new bootstrap.Modal(document.getElementById('messageModal')).show();
    }
</script>
}
