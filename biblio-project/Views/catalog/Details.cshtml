@model biblio_project.Models.BookDetail
@using System.Security.Claims

@{
    ViewData["Title"] = Model.Title;
    var isAuthenticated = User.Identity?.IsAuthenticated ?? false;
    var userId = isAuthenticated ? User.FindFirst(ClaimTypes.NameIdentifier)?.Value : null;
}

<div class="row mb-4">
    <div class="col-12">
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left"></i> Retour au catalogue
        </a>
    </div>
</div>

<div class="row">
    <div class="col-md-4 mb-4">
        @if (!string.IsNullOrEmpty(Model.CoverImageUrl))
        {
            <img src="@Model.CoverImageUrl" class="img-fluid rounded shadow" alt="@Model.Title">
        }
        else
        {
            <div class="bg-secondary rounded shadow d-flex align-items-center justify-content-center"
                 style="height: 500px;">
                <i class="fas fa-book fa-10x text-white"></i>
            </div>
        }

        <div class="mt-3">
            @if (Model.IsAvailable)
            {
                <div class="alert alert-success">
                    <i class="fas fa-check-circle"></i>
                    <strong>@Model.AvailableCopiesCount</strong> exemplaire(s) disponible(s)
                </div>

                @if (isAuthenticated)
                {
                    <button type="button" class="btn btn-primary btn-lg w-100 mb-2"
                            onclick="borrowBook(@Model.Id)">
                        <i class="fas fa-book-reader"></i> Emprunter
                    </button>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login" asp-route-returnUrl="@Context.Request.Path"
                       class="btn btn-primary btn-lg w-100 mb-2">
                        <i class="fas fa-sign-in-alt"></i> Connectez-vous pour emprunter
                    </a>
                }
            }
            else
            {
                <div class="alert alert-warning">
                    <i class="fas fa-exclamation-triangle"></i>
                    Aucun exemplaire disponible
                </div>

                @if (isAuthenticated)
                {
                    <button type="button" class="btn btn-warning btn-lg w-100 mb-2"
                            onclick="reserveBook(@Model.Id)">
                        <i class="fas fa-bookmark"></i> Réserver
                    </button>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login" asp-route-returnUrl="@Context.Request.Path"
                       class="btn btn-warning btn-lg w-100 mb-2">
                        <i class="fas fa-sign-in-alt"></i> Connectez-vous pour réserver
                    </a>
                }
            }

            <p class="text-muted text-center small">
                @Model.TotalCopiesCount exemplaire(s) au total
            </p>
        </div>
    </div>

    <div class="col-md-8">
        <h1 class="display-5">@Model.Title</h1>

        @if (!string.IsNullOrEmpty(Model.Subtitle))
        {
            <h4 class="text-muted mb-3">@Model.Subtitle</h4>
        }

        <hr />

        <div class="mb-4">
            @if (Model.Authors.Any())
            {
                <p class="mb-2">
                    <strong><i class="fas fa-user"></i> Auteur(s) :</strong>
                    @string.Join(", ", Model.Authors.Select(a => a.FullName))
                </p>
            }

            @if (Model.PublicationYear.HasValue)
            {
                <p class="mb-2">
                    <strong><i class="fas fa-calendar"></i> Année de publication :</strong>
                    @Model.PublicationYear
                </p>
            }

            @if (!string.IsNullOrEmpty(Model.PublisherName))
            {
                <p class="mb-2">
                    <strong><i class="fas fa-building"></i> Éditeur :</strong>
                    @Model.PublisherName
                </p>
            }

            @if (Model.Categories.Any())
            {
                <p class="mb-2">
                    <strong><i class="fas fa-tags"></i> Catégories :</strong>
                    @foreach (var category in Model.Categories)
                    {
                        <span class="badge bg-primary me-1">@category.Name</span>
                    }
                </p>
            }
        </div>

        @if (!string.IsNullOrEmpty(Model.Summary))
        {
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h5 class="card-title">
                        <i class="fas fa-align-left"></i> Résumé / Mots-clés
                    </h5>
                    <p class="card-text">@Model.Summary</p>
                </div>
            </div>
        }

        @if (Model.Authors.Any(a => !string.IsNullOrEmpty(a.Bio)))
        {
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h5 class="card-title">
                        <i class="fas fa-info-circle"></i> À propos de l'auteur
                    </h5>
                    @foreach (var author in Model.Authors.Where(a => !string.IsNullOrEmpty(a.Bio)))
                    {
                        <div class="mb-3">
                            <h6>@author.FullName</h6>
                            @if (author.BirthYear.HasValue)
                            {
                                <p class="text-muted small mb-1">
                                    Né en @author.BirthYear
                                    @if (author.DeathYear.HasValue)
                                    {
                                        @:- Décédé en @author.DeathYear
                                    }
                                </p>
                            }
                            <p>@author.Bio</p>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

<!-- Modal de succès/erreur -->
<div class="modal fade" id="messageModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="messageModalTitle">Message</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="messageModalBody">
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Fermer</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // Récupérer l'ID de l'utilisateur authentifié
    const userId = @(isAuthenticated ? userId : "null");
    const isAuthenticated = @(isAuthenticated ? "true" : "false");

    function borrowBook(bookId) {
        if (!isAuthenticated) {
            window.location.href = '/Account/Login?returnUrl=' + encodeURIComponent(window.location.pathname);
            return;
        }

        if (!confirm('Voulez-vous emprunter ce livre ?')) {
            return;
        }

        fetch('/api/loans/borrow', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({
                bookId: bookId,
                userId: userId
            })
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                showMessage('Succès', data.message, 'success');
                setTimeout(() => {
                    location.reload();
                }, 2000);
            } else {
                showMessage('Erreur', data.message, 'error');
            }
        })
        .catch(error => {
            showMessage('Erreur', 'Une erreur est survenue lors de l\'emprunt', 'error');
        });
    }

    function reserveBook(bookId) {
        if (!isAuthenticated) {
            window.location.href = '/Account/Login?returnUrl=' + encodeURIComponent(window.location.pathname);
            return;
        }

        if (!confirm('Voulez-vous réserver ce livre ?')) {
            return;
        }

        fetch('/api/reservations/reserve', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({
                bookId: bookId,
                userId: userId
            })
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                showMessage('Succès', data.message, 'success');
                setTimeout(() => {
                    location.reload();
                }, 2000);
            } else {
                showMessage('Erreur', data.message, 'error');
            }
        })
        .catch(error => {
            showMessage('Erreur', 'Une erreur est survenue lors de la réservation', 'error');
        });
    }

    function showMessage(title, message, type) {
        document.getElementById('messageModalTitle').textContent = title;
        document.getElementById('messageModalBody').innerHTML =
            `<div class="alert alert-${type === 'success' ? 'success' : 'danger'}">
                ${message}
            </div>`;

        const modal = new bootstrap.Modal(document.getElementById('messageModal'));
        modal.show();
    }
</script>
}
